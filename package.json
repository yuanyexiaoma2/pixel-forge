{
  "name": "pixel-forge",
  "private": true,
  "version": "1.0.0",
  "description": "PictureMe - AI Image Generator",
  "author": "PictureMe",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -n vite,server,electron -c blue,green,yellow \"vite\" \"node --watch server/index.js\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "dist": "vite build && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview",
    "server": "node server/index.js",
    "server:dev": "node --watch server/index.js",
    "start": "concurrently -n front,server -c blue,green \"vite\" \"node --watch server/index.js\""
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.3.1",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.pictureme.app",
    "productName": "PictureMe",
    "directories": {
      "output": "release/"
    },
    "files": [
      "electron/",
      "server/",
      "dist/",
      "package.json"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "runAfterFinish": false
    },
    "publish": null,
    "asar": true,
    "asarUnpack": [
      "node_modules/sql.js/**/*"
    ]
  }
}
