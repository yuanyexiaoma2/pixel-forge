# ── 使用说明 ────────────────────────────────────────────
# 1. 将此文件复制并重命名为 .env
#    cp .env.example .env
# 2. 填写下方配置项后保存，重启服务即可生效
# 3. 也可以不填 KIE_API_KEY，启动后在界面内的 API Key 设置里填写
# ────────────────────────────────────────────────────────

# kie.ai API Key（可留空，启动后会弹窗提示填写）
# 获取地址：https://kie.ai/api-key
KIE_API_KEY=

# 后端端口（可选，默认 3001）
PORT=3001

# JWT 密钥（建议修改为随机字符串）
JWT_SECRET=pixel-forge-jwt-secret-change-me
